server:
  port: ${SERVER_PORT:8080}

spring:
  datasource:
    url: ${DATABASE_URL:jdbc:h2:mem:nexustrade}
    username: ${DATABASE_USERNAME:sa}
    password: ${DATABASE_PASSWORD:password}
    driver-class-name: org.h2.Driver
  
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true
  
  
# Supabase configuration (alternative)
# spring:
#   datasource:
#     url: ${SUPABASE_DB_URL:jdbc:postgresql://postgres:${SUPABASE_DB_PASSWORD}@db.########.supabase.co:5432/postgres}
#     username: ${SUPABASE_DB_USERNAME:postgres}
#     password: ${SUPABASE_DB_PASSWORD}
#     driver-class-name: org.postgresql.Driver

app:
  jwt:
    secret: ${JWT_SECRET:mySecretKey123456789012345678901234567890}
    expiration-ms: ${JWT_EXPIRATION_MS:86400000}
